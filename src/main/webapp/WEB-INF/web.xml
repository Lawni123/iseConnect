<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>Archetype Created Web Application</display-name>
  <filter>
  	<filter-name>CheckDuplicateUser</filter-name>
  	<display-name>CheckDuplicateUser</display-name>
  	<description></description>
  	<filter-class>com.iseConnect.authentication.signUp.CheckDuplicateUser</filter-class>
  </filter>
  <filter-mapping>
  	<filter-name>CheckDuplicateUser</filter-name>
  	<url-pattern>/SendOtpServlet</url-pattern>
  </filter-mapping>
  <servlet>
  	<servlet-name>Login</servlet-name>
  	<display-name>Login</display-name>
  	<description></description>
  	<servlet-class>com.iseConnect.authentication.login.Login</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>SendOtpServlet</servlet-name>
  	<display-name>SendOtpServlet</display-name>
  	<description></description>
  	<servlet-class>com.iseConnect.authentication.forgotPassword.SendOtpServlet</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>VerifyEmail</servlet-name>
  	<display-name>VerifyEmail</display-name>
  	<description></description>
  	<servlet-class>com.iseConnect.authentication.forgotPassword.VerifyEmail</servlet-class>
  </servlet>
  <servlet-mapping>
  	<servlet-name>SendOtpServlet</servlet-name>
  	<url-pattern>/SendOtpServlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>VerifyEmail</servlet-name>
  	<url-pattern>/VerifyEmail</url-pattern>
  </servlet-mapping>
  
  <session-config>
  	<session-timeout>30</session-timeout> <!-- in minutes -->
  </session-config>
  
</web-app>
